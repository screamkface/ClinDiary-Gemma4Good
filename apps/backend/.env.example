APP_NAME="ClinDiary API"
ENVIRONMENT=development
DEBUG=true
API_V1_PREFIX=/api/v1
DATABASE_URL=postgresql+psycopg://clindiary:clindiary@localhost:5432/clindiary
REDIS_URL=redis://localhost:6379/0
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30
PASSWORD_RESET_TTL_MINUTES=30
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:5000
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=clindiary
MINIO_SECURE=false
STORAGE_BACKEND=minio
LOCAL_STORAGE_PATH=./.storage
DOCUMENT_MAX_SIZE_MB=20
VIEWER_URL_TTL_MINUTES=15
DOCUMENT_MAGIC_BYTES_VALIDATION=true
DOCUMENT_SCAN_PROVIDER=none
DOCUMENT_SCAN_WEBHOOK_URL=
DOCUMENT_SCAN_FAIL_CLOSED=false
AI_PROVIDER=gemma
AI_MODEL_NAME=gemma-4
SUMMARY_AI_PROVIDER=gemma
SUMMARY_AI_MODEL_NAME=gemma-4
SUMMARY_AI_RUNTIME_MODE=local
DOCUMENT_AI_RUNTIME_MODE=
DOCUMENT_ANSWER_PROVIDER=gemma
DOCUMENT_ANSWER_RUNTIME_MODE=local
EMBEDDING_RUNTIME_MODE=
DOCUMENT_EMBEDDING_PROVIDER=gemma
DOCUMENT_EMBEDDING_RUNTIME_MODE=local
DOCUMENT_RERANKER_PROVIDER=rule_based
LOCAL_LLM_BACKEND=ollama
LOCAL_LLM_BASE_URL=
LOCAL_LLM_MODEL_NAME=
LOCAL_MAX_CONTEXT_TOKENS=8192
LOCAL_EMBEDDING_MODEL_NAME=
LOCAL_EMBEDDING_DIMENSIONS=1024
DOCUMENT_ANSWER_MODEL_NAME=gemma-4
DOCUMENT_EMBEDDING_MODEL_NAME=embeddinggemma
DOCUMENT_EMBEDDING_DIMENSIONS=1024
DOCUMENT_RERANKER_MODEL_NAME=rule_based
DOCUMENT_CHUNK_SIZE_CHARS=1200
DOCUMENT_CHUNK_OVERLAP_CHARS=200
DOCUMENT_CANDIDATE_LIMIT=48
DOCUMENT_RERANK_TOP_N=10
DOCUMENT_ANSWER_TOP_N=6
GOOGLE_OAUTH_CLIENT_ID=
AI_TIMEOUT_SECONDS=60
AI_TEMPERATURE=0.1
AI_MAX_OUTPUT_TOKENS=2048
OCR_PROVIDER=paddleocr
OCR_FALLBACK_PROVIDER=tesseract
OCR_LANGUAGE=it
OCR_USE_GPU=false
OCR_MAX_PAGES=8
OCR_RETRY_ATTEMPTS=2
OCR_TESSERACT_COMMAND=tesseract
OCR_FALLBACK_TO_PENDING=true
CELERY_TASK_ALWAYS_EAGER=false
CELERY_TASK_EAGER_PROPAGATES=false
NOTIFICATION_SYNC_INTERVAL_MINUTES=15
RETENTION_AI_SUMMARIES_DAYS=0
RETENTION_AUDIT_LOGS_DAYS=365
RETENTION_REFRESH_TOKENS_DAYS=30
RETENTION_PASSWORD_RESET_TOKENS_DAYS=7
PASSWORD_RESET_PREVIEW_ENABLED=true
RATE_LIMIT_ENABLED=true
RATE_LIMIT_BACKEND=auto
RATE_LIMIT_AUTH_REQUESTS=30
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_PREFIX=clindiary-rate-limit
NOTIFICATION_PUSH_PROVIDER=log_only
NOTIFICATION_PUSH_WEBHOOK_URL=
NOTIFICATION_FCM_PROJECT_ID=
NOTIFICATION_FCM_ACCESS_TOKEN=
NOTIFICATION_FCM_SERVICE_ACCOUNT_FILE=
NOTIFICATION_FCM_SERVICE_ACCOUNT_JSON=
NOTIFICATION_APNS_KEY_ID=
NOTIFICATION_APNS_TEAM_ID=
NOTIFICATION_APNS_BUNDLE_ID=
NOTIFICATION_APNS_PRIVATE_KEY=
NOTIFICATION_APNS_USE_SANDBOX=true
NOTIFICATION_EMAIL_PROVIDER=log_only
NOTIFICATION_EMAIL_FROM=no-reply@clindiary.local
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
HACKATHON_DEMO_MODE=false
