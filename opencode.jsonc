{
    "$schema": "https://opencode.ai/config.json",
    "model": "{env:OPENCODE_MODEL}",
    "small_model": "{env:OPENCODE_SMALL_MODEL}",
    "share": "manual",
    "lsp": true,
    "formatter": true,
    "watcher": {
        "ignore": [
            "node_modules/**",
            "dist/**",
            "build/**",
            ".dart_tool/**",
            ".gradle/**",
            ".git/**",
            "coverage/**"
        ]
    },
    "compaction": {
        "auto": true,
        "prune": true,
        "reserved": 10000
    },
    "permission": {
        "edit": "ask",
        "bash": {
            "*": "ask",
            "rm -rf *": "deny",
            "git push *": "ask",
            "npm test": "allow",
            "npm run test": "allow",
            "npm run lint": "allow",
            "npm run build": "allow",
            "flutter pub get": "allow",
            "flutter build apk *": "allow",
            "flutter test": "allow",
            "flutter analyze": "allow",
            "make mobile-get": "allow",
            "make mobile-analyze": "allow",
            "make mobile-test": "allow",
            "powershell -ExecutionPolicy Bypass -File scripts/run_android_app.ps1": "allow",
            "powershell -ExecutionPolicy Bypass -File build_demo_apk.ps1": "allow",
            "bash scripts/run_android_app.sh": "allow",
            "bash build_demo_apk.sh": "allow"
        },
        "github_*": "ask",
        "playwright_*": "ask",
        "context7_*": "allow",
        "serena_*": "ask",
        "postgres_*": "ask"
    },
    "mcp": {
        "context7": {
            "type": "remote",
            "url": "https://mcp.context7.com/mcp",
            "headers": {
                "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
            },
            "enabled": true
        },
        "playwright": {
            "type": "local",
            "command": [
                "npx",
                "-y",
                "@playwright/mcp@latest"
            ],
            "enabled": true
        },
        "github": {
            "type": "remote",
            "url": "https://api.githubcopilot.com/mcp/",
            "enabled": false
        },
        "serena": {
            "type": "local",
            "command": [
                "uvx",
                "--from",
                "git+https://github.com/oraios/serena",
                "serena",
                "start-mcp-server"
            ],
            "enabled": false
        }
    }
}